---
import Layout from '../layouts/Layout.astro';
import { loadAllArticles, formatDate } from '../utils/articles';

const allArticles = loadAllArticles();
const siteUrl = 'https://flux.yoandev.co';
---

<Layout title="Partage Twitter" description="Generez des tweets pour partager les articles de veille." noindex>
  <div class="rs-page fade-in-up">

    <div class="rs-two-col">

      <!-- ============ LEFT: Selection ============ -->
      <div class="rs-col">
        <div class="rs-col-header">
          <div class="flex items-center justify-between mb-3">
            <div>
              <h1 class="text-base font-semibold text-white">Selection</h1>
              <p class="text-[11px] text-zinc-500 mt-0.5" id="articles-subtitle"></p>
            </div>
            <div class="flex items-center gap-1.5">
              <button id="select-all" class="rs-btn-ghost">Tout</button>
              <button id="select-none" class="rs-btn-ghost">Aucun</button>
              <button id="select-uncached" class="rs-btn-ghost" title="Selectionner uniquement les articles sans tweet">Nouveaux</button>
            </div>
          </div>

          <!-- Date range -->
          <div class="flex items-center gap-1 mb-3" id="date-range">
            <button class="rs-range-btn rs-range-active" data-days="1">24h</button>
            <button class="rs-range-btn" data-days="3">3j</button>
            <button class="rs-range-btn" data-days="7">7j</button>
            <button class="rs-range-btn" data-days="14">14j</button>
            <button class="rs-range-btn" data-days="30">30j</button>
          </div>
        </div>

        <!-- Article list (scrollable) -->
        <div class="rs-col-scroll">
          <div id="articles-list" class="divide-y divide-zinc-800/50"></div>
          <div id="empty-state" class="hidden py-16 text-center">
            <p class="text-zinc-600 text-sm">Aucun article sur cette periode.</p>
          </div>
        </div>
      </div>

      <!-- ============ RIGHT: Generation ============ -->
      <div class="rs-col">
        <div class="rs-col-header">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-base font-semibold text-white">Tweets</h2>
            <div class="flex items-center gap-2">
              <span id="selection-count" class="text-[11px] text-zinc-600">0 selectionne</span>
              <button id="copy-all" class="rs-btn-ghost hidden flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                Tout copier
              </button>
            </div>
          </div>

          <!-- API Key (inline) -->
          <div class="mb-3">
            <div id="key-saved" class="hidden rs-key-bar">
              <div class="flex items-center gap-2">
                <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/></svg>
                <span class="text-[11px] text-zinc-400">API</span>
                <span class="text-[11px] text-zinc-600 font-mono" id="key-preview"></span>
              </div>
              <button id="change-key" class="text-[11px] text-zinc-700 hover:text-zinc-400 transition-colors cursor-pointer">modifier</button>
            </div>
            <div id="key-form" class="flex gap-1.5">
              <input
                type="password"
                id="api-key"
                placeholder="Cle API Gemini..."
                class="flex-1 px-2.5 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-white placeholder-zinc-700 focus:outline-none focus:border-indigo-500/50 text-xs font-mono transition-colors"
              />
              <button id="save-key" class="rs-btn-primary text-xs px-3 py-1.5">OK</button>
            </div>
            <p id="key-status" class="mt-1 text-[11px] text-zinc-600"></p>
          </div>

          <!-- Buttons -->
          <div class="flex gap-2 mb-0">
          <button id="show-cached" class="rs-btn-cached flex-1 group">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/></svg>
            <span id="show-cached-label">Voir le cache</span>
          </button>
          <button id="generate-btn" class="rs-btn-generate flex-1 group" disabled>
            <svg class="w-4 h-4 transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
            <span id="generate-label">Generer les tweets</span>
          </button>
          </div>
          <div id="progress-bar" class="hidden mt-2">
            <div class="flex items-center justify-between mb-1">
              <span class="text-[11px] text-zinc-500" id="progress-text"></span>
              <span class="text-[11px] text-zinc-600 font-mono" id="progress-pct">0%</span>
            </div>
            <div class="h-1 rounded-full bg-zinc-800 overflow-hidden">
              <div id="progress-fill" class="h-full bg-gradient-to-r from-indigo-500 to-violet-500 transition-all duration-500 ease-out rounded-full" style="width: 0%"></div>
            </div>
          </div>

          <!-- Stats bar -->
          <div id="stats-bar" class="hidden mt-2 flex items-center gap-3 text-[11px]">
            <span class="text-zinc-500"><span id="stat-total">0</span> generes</span>
            <span class="text-emerald-500"><span id="stat-ok">0</span> valides</span>
            <span class="text-amber-500"><span id="stat-over">0</span> &gt;280</span>
            <span class="flex-1"></span>
            <span class="text-zinc-700"><span id="cache-count">0</span> en cache</span>
            <button id="clear-cache" class="text-zinc-700 hover:text-red-400 transition-colors cursor-pointer">vider</button>
          </div>
        </div>

        <!-- Results (scrollable) -->
        <div class="rs-col-scroll">
          <div id="results-content" class="rs-results-list"></div>
          <div id="results-empty" class="py-20 text-center">
            <svg class="w-8 h-8 text-zinc-800 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
            <p class="text-zinc-700 text-xs">Selectionnez des articles et lancez la generation</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ articlesJson: JSON.stringify(allArticles), siteUrl: 'https://flux.yoandev.co' }}>
  const allArticles = JSON.parse(articlesJson);
  let visibleArticles = [];
  let currentDays = 1;

  const $ = (s) => document.querySelector(s);
  const $$ = (s) => document.querySelectorAll(s);

  const apiKeyInput = $('#api-key');
  const saveKeyBtn = $('#save-key');
  const keyStatus = $('#key-status');
  const keySaved = $('#key-saved');
  const keyForm = $('#key-form');
  const keyPreview = $('#key-preview');
  const changeKeyBtn = $('#change-key');
  const generateBtn = $('#generate-btn');
  const selectionCount = $('#selection-count');
  const progressBar = $('#progress-bar');
  const progressFill = $('#progress-fill');
  const progressText = $('#progress-text');
  const progressPct = $('#progress-pct');
  const resultsContent = $('#results-content');
  const resultsEmpty = $('#results-empty');
  const statsBar = $('#stats-bar');
  const articlesList = $('#articles-list');
  const emptyState = $('#empty-state');
  const copyAllBtn = $('#copy-all');

  // --- Cache ---
  const CACHE_KEY = 'flux-rs-tweets';
  const POSTED_KEY = 'flux-rs-posted';

  function getCache() {
    try { return JSON.parse(localStorage.getItem(CACHE_KEY) || '{}'); }
    catch { return {}; }
  }

  function setCache(cache) {
    localStorage.setItem(CACHE_KEY, JSON.stringify(cache));
    updateCacheCount();
  }

  function cacheTweet(articleId, tweet) {
    const cache = getCache();
    cache[articleId] = tweet;
    setCache(cache);
  }

  function updateCacheCount() {
    $('#cache-count').textContent = Object.keys(getCache()).length;
  }

  // --- Posted status ---
  function getPosted() {
    try { return JSON.parse(localStorage.getItem(POSTED_KEY) || '{}'); }
    catch { return {}; }
  }

  function isPosted(articleId) {
    return !!getPosted()[articleId];
  }

  function getPostedDate(articleId) {
    const ts = getPosted()[articleId];
    if (!ts) return null;
    return new Date(ts).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
  }

  function togglePosted(articleId) {
    const posted = getPosted();
    if (posted[articleId]) {
      delete posted[articleId];
    } else {
      posted[articleId] = Date.now();
    }
    localStorage.setItem(POSTED_KEY, JSON.stringify(posted));
    renderArticles();
  }

  $('#clear-cache').addEventListener('click', () => {
    if (confirm('Supprimer tous les tweets en cache ?')) {
      localStorage.removeItem(CACHE_KEY);
      updateCacheCount();
      renderArticles();
      resultsContent.innerHTML = '';
      resultsEmpty.classList.remove('hidden');
      copyAllBtn.classList.add('hidden');
      statsBar.classList.add('hidden');
    }
  });

  updateCacheCount();

  // --- Key management ---
  function maskKey(key) { return key.slice(0, 4) + '····' + key.slice(-4); }

  function showSavedState(key) {
    keyForm.classList.add('hidden');
    keyStatus.classList.add('hidden');
    keySaved.classList.remove('hidden');
    keyPreview.textContent = maskKey(key);
  }

  function showFormState() {
    keySaved.classList.add('hidden');
    keyForm.classList.remove('hidden');
    apiKeyInput.focus();
  }

  const savedKey = localStorage.getItem('flux-gemini-key');
  if (savedKey) { apiKeyInput.value = savedKey; showSavedState(savedKey); }

  saveKeyBtn.addEventListener('click', () => {
    const key = apiKeyInput.value.trim();
    if (key) { localStorage.setItem('flux-gemini-key', key); showSavedState(key); }
    else { keyStatus.textContent = 'Cle requise'; keyStatus.className = 'mt-1 text-[11px] text-red-400'; }
  });

  apiKeyInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') saveKeyBtn.click(); });
  changeKeyBtn.addEventListener('click', showFormState);

  // --- Date range ---
  function filterByDays(days) {
    currentDays = days;
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() - days);
    cutoff.setHours(0, 0, 0, 0);
    visibleArticles = allArticles.filter((a) => new Date(a.pubDate) >= cutoff);
    $$('.rs-range-btn').forEach((btn) => {
      btn.classList.toggle('rs-range-active', parseInt(btn.dataset.days) === days);
    });
    renderArticles();
  }

  $$('.rs-range-btn').forEach((btn) => {
    btn.addEventListener('click', () => filterByDays(parseInt(btn.dataset.days)));
  });

  // --- Render articles ---
  function formatDateLocal(dateStr) {
    return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
  }

  function renderArticles() {
    const cache = getCache();
    const posted = getPosted();
    $('#articles-subtitle').textContent = `${visibleArticles.length} articles · ${currentDays === 1 ? '24h' : currentDays + 'j'}`;

    if (visibleArticles.length === 0) {
      articlesList.innerHTML = '';
      emptyState.classList.remove('hidden');
      return;
    }
    emptyState.classList.add('hidden');

    articlesList.innerHTML = visibleArticles.map((article) => {
      const hasCached = !!cache[article.id];
      return `
        <label class="rs-article-row group" data-id="${article.id}">
          <div class="rs-checkbox-wrap">
            <input type="checkbox" name="article" value="${article.id}" class="peer sr-only" />
            <div class="rs-checkbox">
              <svg class="w-3 h-3 text-white opacity-0 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            </div>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-[13px] text-zinc-300 font-medium leading-snug group-hover:text-white transition-colors line-clamp-2">${escapeHtml(article.title)}</p>
            <div class="flex items-center gap-1.5 mt-1">
              ${article.type === 'podcast' ? '<span class="rs-tag-podcast">Podcast</span>' : ''}
              <span class="text-[11px] text-zinc-600">${escapeHtml(article.source)}</span>
              <span class="text-zinc-800">&middot;</span>
              <span class="text-[11px] text-zinc-700">${formatDateLocal(article.pubDate)}</span>
              ${hasCached ? '<span class="rs-tag-cached">cache</span>' : ''}
              ${posted[article.id] ? '<span class="rs-tag-posted">poste</span>' : ''}
            </div>
          </div>
        </label>`;
    }).join('');

    bindCheckboxes();
    updateCount();
  }

  function bindCheckboxes() {
    $$('.rs-article-row').forEach((row) => {
      const input = row.querySelector('input[type="checkbox"]');
      const box = row.querySelector('.rs-checkbox');
      const check = box.querySelector('svg');

      function sync() {
        if (input.checked) {
          box.classList.add('bg-indigo-500', 'border-indigo-500');
          box.classList.remove('border-zinc-700', 'bg-zinc-900');
          check.classList.replace('opacity-0', 'opacity-100');
          row.classList.add('rs-article-selected');
        } else {
          box.classList.remove('bg-indigo-500', 'border-indigo-500');
          box.classList.add('border-zinc-700', 'bg-zinc-900');
          check.classList.replace('opacity-100', 'opacity-0');
          row.classList.remove('rs-article-selected');
        }
      }

      input.addEventListener('change', () => { sync(); updateCount(); });
      sync();
    });
  }

  // --- Selection ---
  function updateCount() {
    const count = $$('input[name="article"]:checked').length;
    selectionCount.textContent = `${count} selectionne${count > 1 ? 's' : ''}`;
    generateBtn.disabled = count === 0;
  }

  $('#select-all').addEventListener('click', () => {
    $$('input[name="article"]').forEach((cb) => { cb.checked = true; });
    bindCheckboxes(); updateCount();
  });
  $('#select-none').addEventListener('click', () => {
    $$('input[name="article"]').forEach((cb) => { cb.checked = false; });
    bindCheckboxes(); updateCount();
  });
  $('#select-uncached').addEventListener('click', () => {
    const cache = getCache();
    $$('input[name="article"]').forEach((cb) => { cb.checked = !cache[cb.value]; });
    bindCheckboxes(); updateCount();
  });

  // --- Show cached tweets for current period ---
  $('#show-cached').addEventListener('click', () => {
    const cache = getCache();
    const cachedForPeriod = visibleArticles.filter((a) => cache[a.id]);

    if (cachedForPeriod.length === 0) {
      resultsContent.innerHTML = '';
      resultsEmpty.querySelector('p').textContent = 'Aucun tweet en cache sur cette periode.';
      resultsEmpty.classList.remove('hidden');
      copyAllBtn.classList.add('hidden');
      statsBar.classList.add('hidden');
      return;
    }

    resultsContent.innerHTML = '';
    resultsEmpty.classList.add('hidden');
    copyAllBtn.classList.remove('hidden');

    let okCount = 0;
    let overCount = 0;
    for (const article of cachedForPeriod) {
      const tweet = cache[article.id];
      if (tweet.length <= 280) okCount++; else overCount++;
      resultsContent.appendChild(renderTweetCard(article, tweet, null));
    }

    $('#stat-total').textContent = cachedForPeriod.length;
    $('#stat-ok').textContent = okCount;
    $('#stat-over').textContent = overCount;
    statsBar.classList.remove('hidden');
  });

  // --- Copy all ---
  copyAllBtn.addEventListener('click', () => {
    const tweets = [];
    resultsContent.querySelectorAll('[data-tweet]').forEach((el) => tweets.push(el.dataset.tweet));
    if (tweets.length === 0) return;
    navigator.clipboard.writeText(tweets.join('\n\n---\n\n'));
    const orig = copyAllBtn.innerHTML;
    copyAllBtn.textContent = 'Copie !';
    setTimeout(() => (copyAllBtn.innerHTML = orig), 1500);
  });

  // --- Helpers ---
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function getApiKey() {
    return localStorage.getItem('flux-gemini-key') || apiKeyInput.value.trim();
  }

  async function generateTweet(article) {
    const apiKey = getApiKey();
    const fluxUrl = `${siteUrl}/article/${article.id}`;

    const prompt = `Tu vas consulter l'URL suivante et rediger un tweet en francais pour partager cette ressource.

URL de la ressource originale : ${article.link}
Titre : ${article.title}
Source : ${article.source}
Description : ${article.description || ''}

Regles strictes :
- Le tweet DOIT inclure cette URL a la fin : ${fluxUrl}
- Le tweet complet (texte + URL) DOIT faire 280 caracteres MAXIMUM
- En francais
- Pas d'emoji
- Pas de hashtag
- Ton simple, factuel, informatif
- Une ou deux phrases qui resument l'interet de la ressource

Reponds UNIQUEMENT avec le texte du tweet, rien d'autre.`;

    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-pro-preview:generateContent?key=${apiKey}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] }),
      }
    );

    if (!response.ok) {
      const err = await response.json();
      throw new Error(err.error?.message || `Erreur ${response.status}`);
    }

    const data = await response.json();
    return (data.candidates?.[0]?.content?.parts?.[0]?.text || '').trim();
  }

  // --- Render a tweet card ---
  function renderTweetCard(article, tweet, error) {
    const card = document.createElement('div');
    card.className = 'rs-result-card';
    card.dataset.articleId = article.id;

    if (error) {
      card.innerHTML = `
        <div class="rs-tweet-card rs-tweet-error">
          <p class="text-xs text-zinc-400 font-medium mb-1 line-clamp-1">${escapeHtml(article.title)}</p>
          <p class="text-red-400 text-[11px]">${escapeHtml(error)}</p>
          <button class="regen-btn rs-btn-ghost mt-2 flex items-center gap-1 text-[11px]">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
            Reessayer
          </button>
        </div>`;
    } else {
      const len = tweet.length;
      const isOver = len > 280;
      const pct = Math.min((len / 280) * 100, 100);
      const ringColor = isOver ? '#ef4444' : len > 250 ? '#eab308' : '#22c55e';
      const posted = isPosted(article.id);
      const postedDate = getPostedDate(article.id);

      card.innerHTML = `
        <div class="rs-tweet-card group ${posted ? 'rs-tweet-posted' : ''}" data-tweet="${escapeHtml(tweet).replace(/"/g, '&quot;')}">
          <div class="flex items-start justify-between gap-2 mb-2">
            <div class="flex items-center gap-2 flex-1 min-w-0">
              <p class="text-[11px] text-zinc-600 font-medium line-clamp-1">${escapeHtml(article.source)}</p>
              ${posted ? `<span class="rs-tag-posted shrink-0">${postedDate}</span>` : ''}
            </div>
            <div class="rs-ring shrink-0" title="${len}/280">
              <svg width="24" height="24" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="9" fill="none" stroke="#27272a" stroke-width="2"/>
                <circle cx="12" cy="12" r="9" fill="none" stroke="${ringColor}" stroke-width="2"
                  stroke-dasharray="${(pct / 100) * 56.549} 56.549"
                  stroke-linecap="round" transform="rotate(-90 12 12)"
                  class="transition-all duration-500"/>
              </svg>
              <span class="rs-ring-text" style="color: ${isOver ? '#f87171' : '#71717a'}">${len}</span>
            </div>
          </div>
          <p class="text-[13px] text-zinc-200 leading-relaxed mb-2 whitespace-pre-wrap">${escapeHtml(tweet)}</p>
          <div class="flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
            <button class="copy-btn rs-btn-ghost flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              Copier
            </button>
            <button class="posted-btn ${posted ? 'rs-btn-posted-active' : 'rs-btn-ghost'} flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
              ${posted ? 'Poste' : 'Marquer poste'}
            </button>
            <button class="regen-btn rs-btn-ghost flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
              Regenerer
            </button>
          </div>
        </div>`;

      card.querySelector('.copy-btn').addEventListener('click', () => {
        navigator.clipboard.writeText(tweet);
        const btn = card.querySelector('.copy-btn');
        btn.innerHTML = '<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copie !';
        setTimeout(() => {
          btn.innerHTML = '<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copier';
        }, 1500);
      });

      // Posted toggle
      card.querySelector('.posted-btn').addEventListener('click', () => {
        togglePosted(article.id);
        const newCard = renderTweetCard(article, tweet, null);
        card.replaceWith(newCard);
      });
    }

    card.querySelector('.regen-btn').addEventListener('click', async () => {
      const regenBtn = card.querySelector('.regen-btn');
      regenBtn.disabled = true;
      regenBtn.innerHTML = '<svg class="w-3 h-3 animate-spin" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg> ...';
      try {
        const newTweet = await generateTweet(article);
        cacheTweet(article.id, newTweet);
        const newCard = renderTweetCard(article, newTweet, null);
        card.replaceWith(newCard);
        renderArticles();
      } catch (err) {
        regenBtn.disabled = false;
        regenBtn.innerHTML = '<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg> Erreur';
      }
    });

    return card;
  }

  // --- Generate ---
  generateBtn.addEventListener('click', async () => {
    const apiKey = getApiKey();
    if (!apiKey) {
      showFormState();
      keyStatus.textContent = 'Configurez votre cle API';
      keyStatus.className = 'mt-1 text-[11px] text-red-400';
      keyStatus.classList.remove('hidden');
      return;
    }

    const selectedIds = Array.from($$('input[name="article"]:checked')).map((cb) => cb.value);
    if (selectedIds.length === 0) return;

    const selectedArticles = allArticles.filter((a) => selectedIds.includes(a.id));
    const cache = getCache();
    const toGenerate = selectedArticles.filter((a) => !cache[a.id]);
    const fromCache = selectedArticles.filter((a) => cache[a.id]);

    generateBtn.disabled = true;
    $('#generate-label').textContent = 'Generation...';
    resultsContent.innerHTML = '';
    resultsEmpty.classList.add('hidden');
    copyAllBtn.classList.remove('hidden');
    statsBar.classList.add('hidden');

    for (const article of fromCache) {
      resultsContent.appendChild(renderTweetCard(article, cache[article.id], null));
    }

    let okCount = fromCache.filter((a) => cache[a.id].length <= 280).length;
    let overCount = fromCache.filter((a) => cache[a.id].length > 280).length;

    if (toGenerate.length > 0) {
      progressBar.classList.remove('hidden');
      progressFill.style.width = '0%';
      const total = toGenerate.length;
      let done = 0;

      for (const article of toGenerate) {
        progressText.textContent = `${done + 1}/${total} — ${article.title.slice(0, 30)}...`;
        progressPct.textContent = `${Math.round((done / total) * 100)}%`;

        try {
          const tweet = await generateTweet(article);
          cacheTweet(article.id, tweet);
          if (tweet.length <= 280) okCount++; else overCount++;
          resultsContent.appendChild(renderTweetCard(article, tweet, null));
        } catch (error) {
          resultsContent.appendChild(renderTweetCard(article, null, error.message));
        }

        done++;
        progressFill.style.width = `${(done / total) * 100}%`;
        progressPct.textContent = `${Math.round((done / total) * 100)}%`;
      }

      progressText.textContent = 'Termine';
      progressPct.textContent = '100%';
      setTimeout(() => progressBar.classList.add('hidden'), 1000);
    }

    $('#stat-total').textContent = fromCache.length + toGenerate.length;
    $('#stat-ok').textContent = okCount;
    $('#stat-over').textContent = overCount;
    statsBar.classList.remove('hidden');

    generateBtn.disabled = false;
    $('#generate-label').textContent = 'Generer les tweets';
    updateCount();
    renderArticles();
  });

  // --- Init ---
  filterByDays(1);
</script>

