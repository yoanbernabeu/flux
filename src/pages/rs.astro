---
import Layout from '../layouts/Layout.astro';
import { loadAllArticles } from '../utils/articles';

const allArticles = loadAllArticles();
const siteUrl = 'https://flux.yoandev.co';
---

<Layout title="Thread Twitter / LinkedIn" description="Generez des threads pour partager votre veille tech." noindex>
  <div class="rs-page fade-in-up">
    <div class="rs-two-col">

      <!-- ============ LEFT: Selection ============ -->
      <div class="rs-col">
        <div class="rs-col-header">
          <div class="flex items-center justify-between mb-3">
            <div>
              <h1 class="text-base font-semibold text-white">Selection</h1>
              <p class="text-[11px] text-zinc-500 mt-0.5" id="articles-subtitle"></p>
            </div>
            <div class="flex items-center gap-1.5">
              <button id="select-all" class="rs-btn-ghost">Tout</button>
              <button id="select-none" class="rs-btn-ghost">Aucun</button>
            </div>
          </div>

          <!-- Date range -->
          <div class="flex items-center gap-1 mb-0" id="date-range">
            <button class="rs-range-btn rs-range-active" data-days="1">24h</button>
            <button class="rs-range-btn" data-days="3">3j</button>
            <button class="rs-range-btn" data-days="7">7j</button>
            <button class="rs-range-btn" data-days="14">14j</button>
            <button class="rs-range-btn" data-days="30">30j</button>
          </div>
        </div>

        <!-- Article list (scrollable) -->
        <div class="rs-col-scroll">
          <div id="articles-list" class="divide-y divide-zinc-800/50"></div>
          <div id="empty-state" class="hidden py-16 text-center">
            <p class="text-zinc-600 text-sm">Aucun article sur cette periode.</p>
          </div>
        </div>
      </div>

      <!-- ============ RIGHT: Thread ============ -->
      <div class="rs-col">
        <div class="rs-col-header">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-base font-semibold text-white">Thread</h2>
            <span id="selection-count" class="text-[11px] text-zinc-600">0 selectionne</span>
          </div>

          <!-- API Key (inline) -->
          <div class="mb-3">
            <div id="key-saved" class="hidden rs-key-bar">
              <div class="flex items-center gap-2">
                <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/></svg>
                <span class="text-[11px] text-zinc-400">API</span>
                <span class="text-[11px] text-zinc-600 font-mono" id="key-preview"></span>
              </div>
              <button id="change-key" class="text-[11px] text-zinc-700 hover:text-zinc-400 transition-colors cursor-pointer">modifier</button>
            </div>
            <div id="key-form" class="flex gap-1.5">
              <input
                type="password"
                id="api-key"
                placeholder="Cle API Gemini..."
                class="flex-1 px-2.5 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-white placeholder-zinc-700 focus:outline-none focus:border-indigo-500/50 text-xs font-mono transition-colors"
              />
              <button id="save-key" class="rs-btn-primary text-xs px-3 py-1.5">OK</button>
            </div>
            <p id="key-status" class="mt-1 text-[11px] text-zinc-600"></p>
          </div>

          <!-- Generate button -->
          <button id="generate-btn" class="rs-btn-generate w-full group" disabled>
            <svg class="w-4 h-4 transition-transform group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
            <span id="generate-label">Generer le thread</span>
          </button>

          <!-- Loading -->
          <div id="loading-bar" class="hidden mt-2">
            <div class="flex items-center gap-2">
              <svg class="w-3.5 h-3.5 animate-spin text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
              <span class="text-[11px] text-zinc-500" id="loading-text">Generation du thread...</span>
            </div>
          </div>

          <!-- Error -->
          <div id="error-bar" class="hidden mt-2">
            <p class="text-[11px] text-red-400" id="error-text"></p>
          </div>
        </div>

        <!-- Thread display (scrollable) -->
        <div class="rs-col-scroll">
          <div id="thread-content" class="hidden">
            <!-- Action buttons -->
            <div class="flex items-center gap-2 px-4 py-3 border-b border-zinc-800/50">
              <button id="copy-twitter" class="rs-btn-ghost flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                Copier Twitter
              </button>
              <button id="copy-linkedin" class="rs-btn-ghost flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                Copier LinkedIn
              </button>
              <span class="flex-1"></span>
              <button id="regen-btn" class="rs-btn-ghost flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
                Regenerer
              </button>
            </div>
            <!-- Thread tweets list -->
            <div id="thread-tweets"></div>
          </div>
          <div id="thread-empty" class="py-20 text-center">
            <svg class="w-8 h-8 text-zinc-800 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
            <p class="text-zinc-700 text-xs" id="thread-empty-text">Selectionnez des articles et generez le thread</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ articlesJson: JSON.stringify(allArticles), siteUrl: 'https://flux.yoandev.co' }}>
  const allArticles = JSON.parse(articlesJson);
  let visibleArticles = [];
  let currentDays = 1;
  let currentThread = null;
  let currentArticleIds = [];

  const $ = (s) => document.querySelector(s);
  const $$ = (s) => document.querySelectorAll(s);

  const apiKeyInput = $('#api-key');
  const saveKeyBtn = $('#save-key');
  const keyStatus = $('#key-status');
  const keySaved = $('#key-saved');
  const keyForm = $('#key-form');
  const keyPreview = $('#key-preview');
  const changeKeyBtn = $('#change-key');
  const generateBtn = $('#generate-btn');
  const selectionCount = $('#selection-count');
  const loadingBar = $('#loading-bar');
  const loadingText = $('#loading-text');
  const errorBar = $('#error-bar');
  const errorText = $('#error-text');
  const threadContent = $('#thread-content');
  const threadTweets = $('#thread-tweets');
  const threadEmpty = $('#thread-empty');
  const threadEmptyText = $('#thread-empty-text');
  const articlesList = $('#articles-list');
  const emptyState = $('#empty-state');

  // --- Cache ---
  const CACHE_KEY = 'flux-rs-threads';

  function getCache() {
    try { return JSON.parse(localStorage.getItem(CACHE_KEY) || '{}'); }
    catch { return {}; }
  }

  function setCache(cache) {
    localStorage.setItem(CACHE_KEY, JSON.stringify(cache));
  }

  function hashArticleIds(ids) {
    const str = [...ids].sort().join(',');
    let hash = 0;
    for (let i = 0; i < str.length; i++) {
      hash = ((hash << 5) - hash) + str.charCodeAt(i);
      hash |= 0;
    }
    return 't_' + Math.abs(hash).toString(36);
  }

  function getCachedThread(articleIds) {
    return getCache()[hashArticleIds(articleIds)] || null;
  }

  function cacheThread(articleIds, thread) {
    const cache = getCache();
    cache[hashArticleIds(articleIds)] = thread;
    setCache(cache);
  }

  // --- Key management ---
  function maskKey(key) { return key.slice(0, 4) + '····' + key.slice(-4); }

  function showSavedState(key) {
    keyForm.classList.add('hidden');
    keyStatus.classList.add('hidden');
    keySaved.classList.remove('hidden');
    keyPreview.textContent = maskKey(key);
  }

  function showFormState() {
    keySaved.classList.add('hidden');
    keyForm.classList.remove('hidden');
    apiKeyInput.focus();
  }

  const savedKey = localStorage.getItem('flux-gemini-key');
  if (savedKey) { apiKeyInput.value = savedKey; showSavedState(savedKey); }

  saveKeyBtn.addEventListener('click', () => {
    const key = apiKeyInput.value.trim();
    if (key) { localStorage.setItem('flux-gemini-key', key); showSavedState(key); }
    else { keyStatus.textContent = 'Cle requise'; keyStatus.className = 'mt-1 text-[11px] text-red-400'; }
  });

  apiKeyInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') saveKeyBtn.click(); });
  changeKeyBtn.addEventListener('click', showFormState);

  function getApiKey() {
    return localStorage.getItem('flux-gemini-key') || apiKeyInput.value.trim();
  }

  // --- Date range ---
  function filterByDays(days) {
    currentDays = days;
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() - days);
    cutoff.setHours(0, 0, 0, 0);
    visibleArticles = allArticles.filter((a) => new Date(a.pubDate) >= cutoff);
    $$('.rs-range-btn').forEach((btn) => {
      btn.classList.toggle('rs-range-active', parseInt(btn.dataset.days) === days);
    });
    renderArticles();
  }

  $$('.rs-range-btn').forEach((btn) => {
    btn.addEventListener('click', () => filterByDays(parseInt(btn.dataset.days)));
  });

  // --- Helpers ---
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function formatDateLocal(dateStr) {
    return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
  }

  // --- Render articles ---
  function renderArticles() {
    $('#articles-subtitle').textContent = `${visibleArticles.length} articles · ${currentDays === 1 ? '24h' : currentDays + 'j'}`;

    if (visibleArticles.length === 0) {
      articlesList.innerHTML = '';
      emptyState.classList.remove('hidden');
      return;
    }
    emptyState.classList.add('hidden');

    articlesList.innerHTML = visibleArticles.map((article) => `
      <label class="rs-article-row group" data-id="${article.id}">
        <div class="rs-checkbox-wrap">
          <input type="checkbox" name="article" value="${article.id}" class="peer sr-only" />
          <div class="rs-checkbox">
            <svg class="w-3 h-3 text-white opacity-0 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-[13px] text-zinc-300 font-medium leading-snug group-hover:text-white transition-colors line-clamp-2">${escapeHtml(article.title)}</p>
          <div class="flex items-center gap-1.5 mt-1">
            ${article.type === 'podcast' ? '<span class="rs-tag-type rs-tag-podcast">Podcast</span>' : ''}
            ${article.type === 'youtube' ? '<span class="rs-tag-type rs-tag-youtube">YouTube</span>' : ''}
            <span class="text-[11px] text-zinc-600">${escapeHtml(article.source)}</span>
            <span class="text-zinc-800">&middot;</span>
            <span class="text-[11px] text-zinc-700">${formatDateLocal(article.pubDate)}</span>
          </div>
        </div>
      </label>
    `).join('');

    bindCheckboxes();
    updateCount();
  }

  function bindCheckboxes() {
    $$('.rs-article-row').forEach((row) => {
      const input = row.querySelector('input[type="checkbox"]');
      const box = row.querySelector('.rs-checkbox');
      const check = box.querySelector('svg');

      function sync() {
        if (input.checked) {
          box.classList.add('bg-indigo-500', 'border-indigo-500');
          box.classList.remove('border-zinc-700', 'bg-zinc-900');
          check.classList.replace('opacity-0', 'opacity-100');
          row.classList.add('rs-article-selected');
        } else {
          box.classList.remove('bg-indigo-500', 'border-indigo-500');
          box.classList.add('border-zinc-700', 'bg-zinc-900');
          check.classList.replace('opacity-100', 'opacity-0');
          row.classList.remove('rs-article-selected');
        }
      }

      input.addEventListener('change', () => { sync(); updateCount(); });
      sync();
    });
  }

  // --- Selection ---
  function updateCount() {
    const count = $$('input[name="article"]:checked').length;
    selectionCount.textContent = `${count} selectionne${count > 1 ? 's' : ''}`;
    generateBtn.disabled = count === 0;
  }

  $('#select-all').addEventListener('click', () => {
    $$('input[name="article"]').forEach((cb) => { cb.checked = true; });
    bindCheckboxes(); updateCount();
  });
  $('#select-none').addEventListener('click', () => {
    $$('input[name="article"]').forEach((cb) => { cb.checked = false; });
    bindCheckboxes(); updateCount();
  });

  // --- Generate thread ---
  async function generateThread(articles, forceRegen = false) {
    const articleIds = articles.map((a) => a.id);

    // Check cache
    if (!forceRegen) {
      const cached = getCachedThread(articleIds);
      if (cached) {
        currentThread = cached;
        currentArticleIds = articleIds;
        renderThread(cached, articles);
        return;
      }
    }

    const apiKey = getApiKey();
    if (!apiKey) {
      showFormState();
      keyStatus.textContent = 'Configurez votre cle API';
      keyStatus.className = 'mt-1 text-[11px] text-red-400';
      keyStatus.classList.remove('hidden');
      return;
    }

    // Show loading
    generateBtn.disabled = true;
    $('#generate-label').textContent = 'Generation...';
    loadingBar.classList.remove('hidden');
    errorBar.classList.add('hidden');
    threadContent.classList.add('hidden');
    threadEmpty.classList.add('hidden');

    const today = new Date().toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
    const totalTweets = articles.length + 2;

    const articlesPrompt = articles.map((a, i) => {
      const fluxUrl = `${siteUrl}/article/${a.id}`;
      return `Article ${i + 1} (id: ${a.id}) :
- Titre : ${a.title}
- Source : ${a.source}
- Description : ${a.description || 'N/A'}
- Type : ${a.type || 'article'}
- Lien a utiliser dans le tweet : ${fluxUrl}`;
    }).join('\n\n');

    const prompt = `Tu es un community manager tech francophone. A partir de la liste d'articles ci-dessous, genere un thread Twitter complet de ${totalTweets} tweets.

Le thread doit contenir :
1. Un tweet d'introduction (1/${totalTweets}) SANS lien qui resume en une mini-phrase les 2-3 themes principaux des articles, suivi de "(thread)". Exemple : "1/${totalTweets} IA generative, securite cloud et clean architecture : ma selection de ressources tech du ${today} (thread)"
2. Un tweet par article (2/${totalTweets} a ${totalTweets - 1}/${totalTweets}), chacun incluant le lien fourni a la fin
3. Un tweet de cloture (${totalTweets}/${totalTweets}) invitant a decouvrir plus de ressources sur ${siteUrl}

Regles strictes pour CHAQUE tweet :
- 280 caracteres MAXIMUM par tweet (numerotation + texte + lien compris)
- En francais
- Pas d'emoji
- Pas de hashtag
- Ton simple, factuel, informatif
- Chaque tweet commence par sa numerotation (ex: "1/${totalTweets}", "2/${totalTweets}", etc.)
- Pour les tweets d'articles : une ou deux phrases qui resument l'interet, puis le lien

Articles :
${articlesPrompt}

Reponds UNIQUEMENT avec un JSON valide au format :
{"intro":"texte du tweet d'intro avec numerotation","tweets":[{"articleId":"id_de_l_article","text":"texte du tweet avec numerotation et lien"}],"outro":"texte du tweet de cloture avec numerotation"}`;

    try {
      const response = await fetch(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: prompt }] }],
            generationConfig: { responseMimeType: 'application/json' },
          }),
        }
      );

      if (!response.ok) {
        const err = await response.json();
        throw new Error(err.error?.message || `Erreur ${response.status}`);
      }

      const data = await response.json();
      const rawText = (data.candidates?.[0]?.content?.parts?.[0]?.text || '').trim();
      const thread = JSON.parse(rawText);

      if (!thread.intro || !Array.isArray(thread.tweets) || !thread.outro) {
        throw new Error('Format de reponse invalide');
      }

      currentThread = thread;
      currentArticleIds = articleIds;
      cacheThread(articleIds, thread);
      renderThread(thread, articles);
    } catch (error) {
      threadContent.classList.add('hidden');
      threadEmpty.classList.add('hidden');
      errorBar.classList.remove('hidden');
      errorText.textContent = `Erreur : ${error.message}`;
    } finally {
      generateBtn.disabled = false;
      $('#generate-label').textContent = 'Generer le thread';
      loadingBar.classList.add('hidden');
    }
  }

  // --- Render thread ---
  function renderThread(thread, articles) {
    const total = thread.tweets.length + 2;
    threadTweets.innerHTML = '';
    errorBar.classList.add('hidden');

    // Intro tweet
    threadTweets.appendChild(createTweetCard(thread.intro, 1, total, 'intro'));

    // Article tweets
    thread.tweets.forEach((t, i) => {
      const article = articles.find((a) => a.id === t.articleId);
      const sourceName = article ? article.source : '';
      threadTweets.appendChild(createTweetCard(t.text, i + 2, total, 'article', sourceName));
    });

    // Outro tweet
    threadTweets.appendChild(createTweetCard(thread.outro, total, total, 'cloture'));

    threadContent.classList.remove('hidden');
    threadEmpty.classList.add('hidden');
  }

  function createTweetCard(text, num, total, type, sourceName) {
    const card = document.createElement('div');
    card.className = 'rs-thread-tweet group';

    const len = text.length;
    const isOver = len > 280;
    const pct = Math.min((len / 280) * 100, 100);
    const ringColor = isOver ? '#ef4444' : len > 250 ? '#eab308' : '#22c55e';

    const badge = type === 'intro'
      ? '<span class="rs-badge rs-badge-intro">Intro</span>'
      : type === 'cloture'
        ? '<span class="rs-badge rs-badge-cloture">Cloture</span>'
        : '';

    const source = sourceName
      ? `<span class="text-[11px] text-zinc-600">${escapeHtml(sourceName)}</span>`
      : '';

    card.innerHTML = `
      <div class="flex items-start justify-between gap-2 mb-1.5">
        <div class="flex items-center gap-2 min-w-0">
          <span class="text-[11px] text-zinc-500 font-mono font-semibold shrink-0">${num}/${total}</span>
          ${badge}
          ${source}
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <button class="copy-single-btn rs-btn-ghost opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Copier
          </button>
          <div class="rs-ring" title="${len}/280">
            <svg width="24" height="24" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="9" fill="none" stroke="#27272a" stroke-width="2"/>
              <circle cx="12" cy="12" r="9" fill="none" stroke="${ringColor}" stroke-width="2"
                stroke-dasharray="${(pct / 100) * 56.549} 56.549"
                stroke-linecap="round" transform="rotate(-90 12 12)"
                class="transition-all duration-500"/>
            </svg>
            <span class="rs-ring-text" style="color: ${isOver ? '#f87171' : '#71717a'}">${len}</span>
          </div>
        </div>
      </div>
      <p class="text-[13px] text-zinc-200 leading-relaxed whitespace-pre-wrap">${escapeHtml(text)}</p>
    `;

    card.querySelector('.copy-single-btn').addEventListener('click', () => {
      const btn = card.querySelector('.copy-single-btn');
      navigator.clipboard.writeText(text);
      card.classList.add('rs-tweet-copied');
      btn.innerHTML = '<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copie !';
      setTimeout(() => {
        btn.innerHTML = '<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copier';
      }, 1500);
    });

    return card;
  }

  // --- Copy functions ---
  function copyWithFeedback(btn, text) {
    navigator.clipboard.writeText(text);
    const orig = btn.innerHTML;
    btn.textContent = 'Copie !';
    setTimeout(() => (btn.innerHTML = orig), 1500);
  }

  $('#copy-twitter').addEventListener('click', () => {
    if (!currentThread) return;
    const parts = [currentThread.intro];
    currentThread.tweets.forEach((t) => parts.push(t.text));
    parts.push(currentThread.outro);
    copyWithFeedback($('#copy-twitter'), parts.join('\n\n---\n\n'));
  });

  $('#copy-linkedin').addEventListener('click', () => {
    if (!currentThread) return;
    // Strip numbering (e.g. "3/7 ") and "(thread)" for LinkedIn
    const stripNum = (s) => s.replace(/^\d+\/\d+\s*/, '');
    const intro = stripNum(currentThread.intro).replace(/\s*\(thread\)\s*$/i, '');
    const parts = [intro];
    currentThread.tweets.forEach((t) => parts.push(stripNum(t.text)));
    parts.push(stripNum(currentThread.outro));
    copyWithFeedback($('#copy-linkedin'), parts.join('\n\n'));
  });

  // --- Regenerate ---
  $('#regen-btn').addEventListener('click', () => {
    const selectedIds = Array.from($$('input[name="article"]:checked')).map((cb) => cb.value);
    if (selectedIds.length === 0) return;
    const selectedArticles = allArticles.filter((a) => selectedIds.includes(a.id));
    generateThread(selectedArticles, true);
  });

  // --- Generate button ---
  generateBtn.addEventListener('click', () => {
    const selectedIds = Array.from($$('input[name="article"]:checked')).map((cb) => cb.value);
    if (selectedIds.length === 0) return;
    const selectedArticles = allArticles.filter((a) => selectedIds.includes(a.id));
    generateThread(selectedArticles);
  });

  // --- Init ---
  filterByDays(1);
</script>

