---
import Layout from '../layouts/Layout.astro';
import ArticleListPage from '../components/ArticleListPage.astro';
import { loadAllArticles, getAllCategories, getAllSources, getAllTypes } from '../utils/articles';

const PAGE_SIZE = 15;
const allArticles = loadAllArticles();
const categories = getAllCategories(allArticles);
const sources = getAllSources(allArticles);
const types = getAllTypes(allArticles);
const totalPages = Math.max(1, Math.ceil(allArticles.length / PAGE_SIZE));
const articles = allArticles.slice(0, PAGE_SIZE);
---

<Layout title="Veille technologique" description={`${allArticles.length} articles de veille technologique agrégés depuis ${sources.length} sources — Programmation, IA, DevOps, Cloud, Web et Cybersécurité.`} image="https://flux.yoandev.co/og.webp">
  <ArticleListPage
    articles={articles}
    categories={categories}
    sources={sources}
    types={types}
    currentPage={1}
    totalPages={totalPages}
  />
</Layout>
