---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { loadAllArticles, getAllSources, getCategoryColor } from '../../utils/articles';

export function getStaticPaths() {
  const PAGE_SIZE = 15;
  const allArticles = loadAllArticles();
  const sources = getAllSources(allArticles);
  const paths: any[] = [];

  for (const source of sources) {
    const sourceArticles = allArticles.filter((a) => a.source === source.name);
    const totalPages = Math.max(1, Math.ceil(sourceArticles.length / PAGE_SIZE));

    for (let page = 1; page <= totalPages; page++) {
      const start = (page - 1) * PAGE_SIZE;
      paths.push({
        params: { slug: page === 1 ? source.slug : `${source.slug}/${page}` },
        props: {
          source,
          articles: sourceArticles.slice(start, start + PAGE_SIZE),
          currentPage: page,
          totalPages,
          totalArticles: sourceArticles.length,
        },
      });
    }
  }

  return paths;
}

const { source, articles, currentPage, totalPages, totalArticles } = Astro.props;

function pageUrl(page: number): string {
  return page === 1 ? `/source/${source.slug}` : `/source/${source.slug}/${page}`;
}

const pages: (number | string)[] = [];
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
    pages.push(i);
  } else if (pages[pages.length - 1] !== '...') {
    pages.push('...');
  }
}
---

<Layout title={currentPage > 1 ? `${source.name} — Page ${currentPage}` : source.name} description={`Tous les articles de ${source.name} agrégés par Flux — Veille technologique francophone.`}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://flux.yoandev.co/" },
      { "@type": "ListItem", "position": 2, "name": "Sources", "item": "https://flux.yoandev.co/sources/" },
      { "@type": "ListItem", "position": 3, "name": source.name },
    ]
  })} />
  <div class="fade-in-up">
    <div class="mb-8">
      <!-- Breadcrumb -->
      <nav aria-label="Fil d'Ariane" class="mb-3">
        <ol class="flex items-center gap-1.5 text-xs text-zinc-500">
          <li><a href="/" class="hover:text-indigo-400 transition-colors">Accueil</a></li>
          <li class="text-zinc-700">/</li>
          <li><a href="/sources" class="hover:text-indigo-400 transition-colors">Sources</a></li>
          <li class="text-zinc-700">/</li>
          <li class="text-zinc-400">{source.name}</li>
        </ol>
      </nav>
      <a href="/sources" class="text-xs text-zinc-500 hover:text-indigo-400 transition-colors mb-3 inline-flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
        Toutes les sources
      </a>
      <h1 class="text-2xl sm:text-3xl font-bold mb-2">{source.name}</h1>
      <div class="flex items-center gap-3 mb-3">
        <span class="text-zinc-400 text-sm">{totalArticles} article{totalArticles > 1 ? 's' : ''}</span>
        <a
          href={source.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-zinc-500 hover:text-indigo-400 transition-colors inline-flex items-center gap-1"
        >
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
          Flux RSS
        </a>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {source.categories.map((cat: string) => (
          <span class={`px-2 py-0.5 text-xs font-medium rounded-full border ${getCategoryColor(cat)}`}>
            {cat}
          </span>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {articles.map((article: any) => (
        <ArticleCard article={article} />
      ))}
    </div>

    {articles.length === 0 && (
      <div class="text-center py-20 text-zinc-500">
        <p class="text-lg font-medium">Aucun article pour cette source</p>
      </div>
    )}

    {totalPages > 1 && (
      <nav aria-label="Pagination" class="flex items-center justify-center gap-1.5 mt-8">
        {currentPage > 1 && (
          <a href={pageUrl(currentPage - 1)} class="px-3 py-2 text-sm rounded-lg border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 transition-all" aria-label="Page précédente">←</a>
        )}
        {pages.map((p) => (
          p === '...' ? (
            <span class="px-2 py-2 text-sm text-zinc-600">…</span>
          ) : p === currentPage ? (
            <span class="px-3 py-2 text-sm rounded-lg bg-indigo-500/20 border border-indigo-500/50 text-indigo-400 font-medium" aria-current="page">{p}</span>
          ) : (
            <a href={pageUrl(p as number)} class="px-3 py-2 text-sm rounded-lg border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 transition-all">{p}</a>
          )
        ))}
        {currentPage < totalPages && (
          <a href={pageUrl(currentPage + 1)} class="px-3 py-2 text-sm rounded-lg border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 transition-all" aria-label="Page suivante">→</a>
        )}
      </nav>
    )}
  </div>
</Layout>
