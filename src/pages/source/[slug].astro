---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { loadAllArticles, getAllSources, getCategoryColor, formatDate } from '../../utils/articles';

export function getStaticPaths() {
  const allArticles = loadAllArticles();
  const sources = getAllSources(allArticles);

  return sources.map((source) => ({
    params: { slug: source.slug },
    props: {
      source,
      articles: allArticles.filter((a) => a.source === source.name),
    },
  }));
}

const { source, articles } = Astro.props;
---

<Layout title={source.name} description={`Tous les articles de ${source.name} agrégés par Flux.`} noindex>
  <div class="fade-in-up">
    <div class="mb-8">
      <a href="/sources" class="text-xs text-zinc-500 hover:text-indigo-400 transition-colors mb-3 inline-flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
        Toutes les sources
      </a>
      <h1 class="text-2xl sm:text-3xl font-bold mb-2">{source.name}</h1>
      <div class="flex items-center gap-3 mb-3">
        <span class="text-zinc-400 text-sm">{articles.length} article{articles.length > 1 ? 's' : ''}</span>
        <a
          href={source.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-zinc-500 hover:text-indigo-400 transition-colors inline-flex items-center gap-1"
        >
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
          Flux RSS
        </a>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {source.categories.map((cat: string) => (
          <span class={`px-2 py-0.5 text-xs font-medium rounded-full border ${getCategoryColor(cat)}`}>
            {cat}
          </span>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {articles.map((article: any) => (
        <ArticleCard article={article} />
      ))}
    </div>

    {articles.length === 0 && (
      <div class="text-center py-20 text-zinc-500">
        <p class="text-lg font-medium">Aucun article pour cette source</p>
      </div>
    )}
  </div>
</Layout>
