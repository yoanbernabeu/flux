---
import Layout from '../layouts/Layout.astro';
import { loadAllArticles, getAllCategories, getAllSources, getCategoryColor, slugify } from '../utils/articles';

const allArticles = loadAllArticles();
const categories = getAllCategories(allArticles);
const sources = getAllSources(allArticles);

// Articles par catégorie
const catStats = categories.map((cat) => ({
  name: cat,
  slug: slugify(cat),
  count: allArticles.filter((a) => a.categories.includes(cat)).length,
})).sort((a, b) => b.count - a.count);

const maxCatCount = Math.max(...catStats.map((c) => c.count));

// Top 10 sources par nombre d'articles
const topSources = sources.slice().sort((a, b) => b.count - a.count).slice(0, 10);
const maxSourceCount = Math.max(...topSources.map((s) => s.count));

// Articles par mois
const monthMap = new Map<string, number>();
for (const article of allArticles) {
  const d = new Date(article.pubDate);
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  monthMap.set(key, (monthMap.get(key) || 0) + 1);
}
const monthStats = Array.from(monthMap.entries())
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([month, count]) => ({
    month,
    label: new Date(month + '-01').toLocaleDateString('fr-FR', { month: 'short', year: 'numeric' }),
    shortLabel: new Date(month + '-01').toLocaleDateString('fr-FR', { month: 'short' }),
    count,
  }));
const maxMonthCount = Math.max(...monthStats.map((m) => m.count));

// Articles par type
const typeMap = new Map<string, number>();
for (const article of allArticles) {
  const type = article.type || 'blog';
  typeMap.set(type, (typeMap.get(type) || 0) + 1);
}
const typeLabels: Record<string, string> = { blog: 'Articles', podcast: 'Podcasts', youtube: 'YouTube' };
const typeIcons: Record<string, string> = { blog: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2', podcast: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m-4 0h8M12 4a3 3 0 00-3 3v4a3 3 0 006 0V7a3 3 0 00-3-3z', youtube: 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z M21 12a9 9 0 11-18 0 9 9 0 0118 0z' };
const typeColors: Record<string, string> = { blog: 'from-indigo-500 to-violet-500', podcast: 'from-emerald-500 to-teal-500', youtube: 'from-rose-500 to-pink-500' };
const typeBgColors: Record<string, string> = { blog: 'bg-indigo-500/10 border-indigo-500/20 text-indigo-400', podcast: 'bg-emerald-500/10 border-emerald-500/20 text-emerald-400', youtube: 'bg-rose-500/10 border-rose-500/20 text-rose-400' };
const typeStats = Array.from(typeMap.entries())
  .map(([type, count]) => ({ type, label: typeLabels[type] || type, count }))
  .sort((a, b) => b.count - a.count);

// Moyenne articles par mois
const avgPerMonth = monthStats.length > 0 ? Math.round(allArticles.length / monthStats.length) : 0;

// Podium medals
const medals = ['text-amber-400', 'text-zinc-400', 'text-amber-700'];
---

<Layout title="Statistiques" description={`Statistiques de Flux — ${allArticles.length} articles, ${sources.length} sources, ${categories.length} catégories de veille technologique.`}>
  <div class="fade-in-up">
    <div class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold mb-2">Statistiques</h1>
      <p class="text-zinc-400 text-sm">
        Vue d'ensemble de la veille technologique agrégée par Flux
      </p>
    </div>

    <!-- Chiffres clés -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
      <div class="relative overflow-hidden rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] p-6">
        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-bl from-indigo-500/10 to-transparent rounded-bl-full"></div>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center">
            <svg class="w-4.5 h-4.5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2" />
            </svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-white tracking-tight">{allArticles.length.toLocaleString('fr-FR')}</p>
        <p class="text-xs text-zinc-500 mt-1">Articles agrégés</p>
      </div>

      <div class="relative overflow-hidden rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] p-6">
        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-bl from-violet-500/10 to-transparent rounded-bl-full"></div>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-lg bg-violet-500/10 border border-violet-500/20 flex items-center justify-center">
            <svg class="w-4.5 h-4.5 text-violet-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/>
            </svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-white tracking-tight">{sources.length}</p>
        <p class="text-xs text-zinc-500 mt-1">Sources suivies</p>
      </div>

      <div class="relative overflow-hidden rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] p-6">
        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-bl from-emerald-500/10 to-transparent rounded-bl-full"></div>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
            <svg class="w-4.5 h-4.5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-white tracking-tight">{categories.length}</p>
        <p class="text-xs text-zinc-500 mt-1">Catégories</p>
      </div>

      <div class="relative overflow-hidden rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] p-6">
        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-bl from-amber-500/10 to-transparent rounded-bl-full"></div>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-lg bg-amber-500/10 border border-amber-500/20 flex items-center justify-center">
            <svg class="w-4.5 h-4.5 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-white tracking-tight">~{avgPerMonth}</p>
        <p class="text-xs text-zinc-500 mt-1">Articles / mois</p>
      </div>
    </div>

    <!-- Articles par type — cartes visuelles -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold mb-5 flex items-center gap-2">
        <span class="w-1 h-5 rounded-full bg-gradient-to-b from-emerald-500 to-teal-500"></span>
        Répartition par type
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {typeStats.map((t) => (
          <div class={`rounded-xl border p-5 ${typeBgColors[t.type] || 'bg-zinc-500/10 border-zinc-500/20 text-zinc-400'}`}>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-2.5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={typeIcons[t.type] || typeIcons.blog} />
                </svg>
                <span class="text-sm font-medium">{t.label}</span>
              </div>
              <span class="text-xs opacity-70">{Math.round((t.count / allArticles.length) * 100)}%</span>
            </div>
            <p class="text-2xl font-bold text-white">{t.count.toLocaleString('fr-FR')}</p>
            <div class="mt-3 h-1.5 rounded-full bg-white/5 overflow-hidden">
              <div
                class={`h-full rounded-full bg-gradient-to-r ${typeColors[t.type] || 'from-zinc-500 to-zinc-400'}`}
                style={`width: ${Math.round((t.count / allArticles.length) * 100)}%`}
              ></div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Articles par mois -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold mb-5 flex items-center gap-2">
        <span class="w-1 h-5 rounded-full bg-gradient-to-b from-indigo-500 to-violet-500"></span>
        Évolution mensuelle
      </h2>
      <div class="rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] p-6">
        <div class="flex items-end gap-1 sm:gap-1.5 h-48 sm:h-56">
          {monthStats.map((m, i) => {
            const pct = (m.count / maxMonthCount) * 100;
            const isLast = i === monthStats.length - 1;
            return (
              <div class="flex-1 flex flex-col items-center gap-1 h-full justify-end group cursor-default" title={`${m.label} : ${m.count} articles`}>
                <span class={`text-[10px] font-medium transition-opacity ${isLast ? 'text-indigo-400 opacity-100' : 'text-zinc-500 opacity-0 group-hover:opacity-100'}`}>{m.count}</span>
                <div
                  class={`w-full rounded-t transition-all ${isLast ? 'bg-gradient-to-t from-indigo-500 to-indigo-400 shadow-lg shadow-indigo-500/20' : 'bg-gradient-to-t from-indigo-600/80 to-indigo-500/60 group-hover:from-indigo-500 group-hover:to-indigo-400'}`}
                  style={`height: ${Math.max(pct, 2)}%`}
                ></div>
                <span class={`text-[8px] sm:text-[9px] whitespace-nowrap ${isLast ? 'text-zinc-400 font-medium' : 'text-zinc-600'}`}>{m.shortLabel}</span>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Grille catégories + sources -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-12">

      <!-- Articles par catégorie -->
      <section>
        <h2 class="text-lg font-semibold mb-5 flex items-center gap-2">
          <span class="w-1 h-5 rounded-full bg-gradient-to-b from-violet-500 to-purple-500"></span>
          Par catégorie
        </h2>
        <div class="rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] p-5 space-y-4">
          {catStats.map((cat) => {
            const pct = Math.round((cat.count / maxCatCount) * 100);
            return (
              <a href={`/categorie/${cat.slug}`} class="block group">
                <div class="flex items-center justify-between mb-1.5">
                  <span class={`px-2 py-0.5 text-xs font-medium rounded-full border ${getCategoryColor(cat.name)} transition-all group-hover:scale-105`}>{cat.name}</span>
                  <span class="text-xs text-zinc-500 tabular-nums">{cat.count}</span>
                </div>
                <div class="h-2 rounded-full bg-zinc-800/80 overflow-hidden">
                  <div
                    class="h-full rounded-full bg-gradient-to-r from-indigo-500 to-violet-500 transition-all group-hover:from-indigo-400 group-hover:to-violet-400"
                    style={`width: ${pct}%`}
                  ></div>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <!-- Top 10 sources -->
      <section>
        <h2 class="text-lg font-semibold mb-5 flex items-center gap-2">
          <span class="w-1 h-5 rounded-full bg-gradient-to-b from-amber-500 to-orange-500"></span>
          Top 10 sources
        </h2>
        <div class="rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] p-5">
          <div class="space-y-1">
            {topSources.map((source, i) => {
              const pct = Math.round((source.count / maxSourceCount) * 100);
              return (
                <a href={`/source/${source.slug}`} class="flex items-center gap-3 group py-2.5 px-2 -mx-2 rounded-lg hover:bg-white/[0.03] transition-colors">
                  <span class={`w-6 text-center text-xs font-bold tabular-nums ${i < 3 ? medals[i] : 'text-zinc-600'}`}>
                    {i + 1}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between mb-1">
                      <span class="text-sm text-zinc-300 group-hover:text-white transition-colors truncate">{source.name}</span>
                      <span class="text-xs text-zinc-500 tabular-nums ml-2 shrink-0">{source.count}</span>
                    </div>
                    <div class="h-1 rounded-full bg-zinc-800/80 overflow-hidden">
                      <div
                        class={`h-full rounded-full transition-all ${i === 0 ? 'bg-gradient-to-r from-amber-400 to-amber-500' : i === 1 ? 'bg-gradient-to-r from-zinc-400 to-zinc-300' : i === 2 ? 'bg-gradient-to-r from-amber-700 to-amber-600' : 'bg-gradient-to-r from-amber-500/60 to-orange-500/60 group-hover:from-amber-500/80 group-hover:to-orange-500/80'}`}
                        style={`width: ${pct}%`}
                      ></div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>

    </div>
  </div>
</Layout>
