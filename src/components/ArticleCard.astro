---
import type { Article } from '../types/index';
import { getFreshnessBadge, formatDate, getCategoryGradient, getCategoryColor, getTypeLabel, getTypeColor, slugify } from '../utils/articles';

interface Props {
  article: Article;
}

const { article } = Astro.props;
const badge = getFreshnessBadge(article.pubDate);
---

<article
  class="card-hover group rounded-xl border border-zinc-800 bg-[var(--color-surface-1)] overflow-hidden fade-in-up flex flex-col"
  data-article-id={article.id}
  data-source={article.source}
  data-categories={article.categories.join(',')}
  data-title={article.title}
  data-description={article.description}
>
  <!-- Image -->
  <a href={`/article/${article.id}`} class="block relative aspect-[16/9] overflow-hidden">
    {article.image ? (
      <img
        src={article.image}
        alt={article.title}
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
      />
      <div class={`w-full h-full bg-gradient-to-br ${getCategoryGradient(article.categories)} items-center justify-center p-5 hidden`}>
        <span class="text-sm font-medium text-white/50 line-clamp-3 text-center leading-relaxed">{article.title}</span>
      </div>
    ) : (
      <div class={`w-full h-full bg-gradient-to-br ${getCategoryGradient(article.categories)} flex items-center justify-center p-5`}>
        <span class="text-sm font-medium text-white/50 line-clamp-3 text-center leading-relaxed">{article.title}</span>
      </div>
    )}
    {badge && (
      <span class={`absolute top-3 left-3 px-2 py-0.5 text-xs font-medium rounded-full ${badge.class}`}>
        {badge.label}
      </span>
    )}
    {(article.type === 'podcast' || article.type === 'youtube') && (
      <span class={`absolute top-3 right-3 px-2 py-0.5 text-xs font-medium rounded-full border ${getTypeColor(article.type)}`}>
        {getTypeLabel(article.type)}
      </span>
    )}
  </a>

  <!-- Content -->
  <div class="p-4 flex flex-col gap-3 flex-1">
    <!-- Categories -->
    <div class="flex flex-wrap gap-1.5">
      {article.categories.map((cat) => (
        <a href={`/categorie/${slugify(cat)}`} class={`px-2 py-0.5 text-xs font-medium rounded-full border ${getCategoryColor(cat)} hover:opacity-80 transition-opacity`}>
          {cat}
        </a>
      ))}
    </div>

    <!-- Title -->
    <h3 class="font-semibold text-sm leading-snug line-clamp-2">
      <a href={`/article/${article.id}`} class="hover:text-indigo-400 transition-colors">
        {article.title}
      </a>
    </h3>

    <!-- Description -->
    <p class="text-xs text-zinc-400 line-clamp-3 leading-relaxed">{article.description}</p>

    <!-- Meta -->
    <div class="flex items-center justify-between text-xs text-zinc-500 pt-1">
      <time datetime={article.pubDate}>{formatDate(article.pubDate)}</time>
    </div>

    <!-- Source CTA -->
    <a
      href={article.link}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-between gap-3 mt-auto px-3.5 py-2.5 rounded-xl bg-indigo-500/10 border border-indigo-500/20 hover:bg-indigo-500/20 hover:border-indigo-500/40 transition-all duration-200 group/cta"
    >
      <div class="flex items-center gap-2 min-w-0">
        <div class="w-6 h-6 rounded-lg bg-indigo-500/20 flex items-center justify-center shrink-0">
          <svg class="w-3 h-3 text-indigo-400" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
        </div>
        <span class="text-xs font-medium text-indigo-300 truncate">{article.source}</span>
      </div>
      <div class="flex items-center gap-1 text-xs text-indigo-400 group-hover/cta:text-indigo-300 shrink-0">
        <span class="hidden sm:inline">Lire</span>
        <svg class="w-3.5 h-3.5 group-hover/cta:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </div>
    </a>
  </div>
</article>
